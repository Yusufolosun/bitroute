{
  "name": "defikit",
  "version": "1.0.0",
  "description": "Lightweight, zero-dependency DeFi math utilities — basis points, fees, slippage, AMM math, token amounts, and yield calculations.",
  "author": "Yusuf Olosun",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  },
  "keywords": [
    "defi",
    "finance",
    "basis-points",
    "bps",
    "slippage",
    "amm",
    "uniswap",
    "swap",
    "fee",
    "yield",
    "apr",
    "apy",
    "token",
    "bigint",
    "math",
    "constant-product",
    "impermanent-loss",
    "price-impact",
    "dex",
    "web3",
    "blockchain",
    "ethereum",
    "solana",
    "stacks"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Yusufolosun/bitroute.git",
    "directory": "packages/defikit"
  },
  "bugs": {
    "url": "https://github.com/Yusufolosun/bitroute/issues"
  },
  "homepage": "https://github.com/Yusufolosun/bitroute/tree/main/packages/defikit#readme"
}
